# Tauri updater signing
TAURI_SIGNING_PRIVATE_KEY=/path/to/your.key
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Firebase mobile sync
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Google Cloud OAuth client of type "Desktop app" for loopback sign-in
VITE_GOOGLE_DESKTOP_CLIENT_ID=
# GitHub OAuth App client ID with Device Flow enabled
VITE_GITHUB_OAUTH_CLIENT_ID=
